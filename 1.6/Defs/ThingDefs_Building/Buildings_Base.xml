<?xml version="1.0" encoding="utf-8"?>
<Defs>
 <!-- Drying Rack Base-->
 <ThingDef Abstract="True" Name="DryingRackBase" ParentName="BuildingBase">
    <graphicData>
      <texPath>Things/Building/Processor/DryingRack/DryingRack</texPath>
      <graphicClass>Graphic_Multi</graphicClass>
      <shaderType>CutoutComplex</shaderType>
      <drawSize>(2.75,2.75)</drawSize>
      <damageData>
		<rect>(0.05,0.1,0.9,0.9)</rect>
	  </damageData>
    </graphicData>
    <thingCategories>
      <li>BuildingsProduction</li>
    </thingCategories>
    <tickerType>Rare</tickerType>
    <size>(2,1)</size>
    <designationCategory>Production</designationCategory>
    <passability>PassThroughOnly</passability>
    <fillPercent>0.5</fillPercent>
    <pathCost>70</pathCost>
    <minifiedDef>MinifiedThing</minifiedDef>
</ThingDef>

<!-- Fermenter Barrel Base -->
<ThingDef Abstract="True" Name="BasicFermenterBase" ParentName="BuildingBase">
	<graphicData>
      <texPath>Things/Building/Production/WoodenBarrel/WoodenBarrel</texPath>
      <graphicClass>Graphic_Multi</graphicClass>
      <shaderType>CutoutComplex</shaderType>
      <damageData>
        <rect>(0.05,0.1,0.9,0.9)</rect>
      </damageData>
      <shadowData>
        <volume>(0.75, 0.35, 0.33)</volume>
      </shadowData>
    </graphicData>
    <thingCategories>
		<li>BuildingsProduction</li>
	</thingCategories>
	<rotatable>true</rotatable>
	<neverMultiSelect>true</neverMultiSelect>
	<useHitPoints>true</useHitPoints>
    <tickerType>Rare</tickerType>
    <size>(1,1)</size>
    <uiOrder>2001</uiOrder>
	<designationCategory>Production</designationCategory>
	<passability>PassThroughOnly</passability>
    <fillPercent>0.45</fillPercent>
    <pathCost>42</pathCost>
    <constructionSkillPrerequisite>4</constructionSkillPrerequisite>
    <minifiedDef>MinifiedThing</minifiedDef>
</ThingDef>

