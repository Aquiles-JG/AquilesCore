<?xml version="1.0" encoding="utf-8"?>
<Defs>
  <HediffDef>
    <defName>Aq_HulkModifierStat</defName>
    <label>hulk</label>
    <description>A pawn with the hulk body type.</description>
    <descriptionShort>A hulk pawn.</descriptionShort>
    <hediffClass>HediffWithComps</hediffClass>
    <makesSickThought>false</makesSickThought>
    <isBad>false</isBad>
    <tendable>false</tendable>
    <scenarioCanAdd>false</scenarioCanAdd>
    <allowMothballIfLowPriorityWorldPawn>true</allowMothballIfLowPriorityWorldPawn>
    <priceOffset>150</priceOffset>
    <stages>
      <li>
        <label></label>
        <becomeVisible>false</becomeVisible>
        <minSeverity>0.01</minSeverity>
        <hungerRateFactor>1.2</hungerRateFactor>
        <statFactors>
          <Aq_BodySizeFactor>1.1</Aq_BodySizeFactor>
          <ArrestSuccessChance>1.25</ArrestSuccessChance>
          <MeleeDamageFactor>1.2</MeleeDamageFactor>
          <MeleeDodgeChance>0.9</MeleeDodgeChance>
          <MoveSpeed>0.95</MoveSpeed>
          <RestFallRateFactor>1.05</RestFallRateFactor>
          <StaggerDurationFactor>0.85</StaggerDurationFactor>
          <WorkSpeedGlobal>0.95</WorkSpeedGlobal>
        </statFactors>
        <statOffsets>
          <ComfyTemperatureMax>-2</ComfyTemperatureMax>
          <ComfyTemperatureMin>2</ComfyTemperatureMin>
        </statOffsets>
      </li>
    </stages>
  </HediffDef>
  
